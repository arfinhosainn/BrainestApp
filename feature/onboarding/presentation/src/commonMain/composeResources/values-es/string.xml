    <!-- Onboarding Steps -->
    <string name="onboarding_step1_title">Chatea con tu tutor de IA.</string>
    <string name="onboarding_step1_desc">Haz preguntas y obtén ayuda personalizada con matemáticas, ciencias y mucho más.</string>
    <string name="onboarding_step2_title">Captura y resuelve preguntas</string>
    <string name="onboarding_step2_desc">Toma una foto de cualquier pregunta y obtén explicaciones instantáneas paso a paso gracias a la inteligencia artificial.</string>
    <string name="onboarding_step3_title">Crea tarjetas didácticas y cuestionarios.</string>
    <string name="onboarding_step3_desc">Convierte las lecciones en tarjetas de memoria y cuestionarios rápidos para poner a prueba tus conocimientos.</string>

    <!-- User Review Screen -->
    <string name="continue_label">Continuar</string>
    <string name="join_others">Únete a más de 50.000 personas que están alcanzando sus metas.</string>
    <string name="trusted_by_thousands">Con la confianza de miles de personas.</string>
    <string name="rating_score">4.8</string>
    <string name="app_store_rating">Calificación promedio en la App Store</string>
    
    <string name="review1_title">¡Justo lo que necesitaba!</string>
    <string name="review1_name">Felicia2</string>
    <string name="review1_content">¡Sencilla, rápida y eficaz! Había alcanzado mi peso máximo y me sentía bastante desesperanzada. Esta aplicación es sencilla, apta para personas con TDAH y me ayuda a ser realmente consciente de los alimentos que consumo.</string>
    
    <string name="review2_title">¡Un cambio radical!</string>
    <string name="review2_name">Alex_Dev</string>
    <string name="review2_content">Por fin una aplicación que no se siente como una tarea pesada. Registrar los alimentos es realmente divertido y la interfaz de usuario es increíblemente fluida.</string>
    
    <string name="review3_title">Muy recomendable</string>
    <string name="review3_name">SarahM</string>
    <string name="review3_content">He probado todos los rastreadores que existen, pero Brainest es el único que me ha convencido. Su sencillez es su mayor virtud.</string>


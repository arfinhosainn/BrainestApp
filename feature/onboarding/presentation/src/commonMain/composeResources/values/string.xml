    <string name="review1_title">Exactly what I needed!</string>
    <string name="review1_name">Felicia2</string>
    <string name="review1_content">Simple, fast, and effective! I have reached the heaviest weight of my life and was feeling pretty hopeless. This app is simple, ADHD friendly, and helps me to really be aware of the foods I eat.</string>
    
    <string name="review2_title">Game changer!</string>
    <string name="review2_name">Alex_Dev</string>
    <string name="review2_content">Finally an app that doesn\'t feel like a chore. The food logging is actually fun and the UI is incredibly smooth.</string>
    
    <string name="review3_title">Highly Recommend</string>
    <string name="review3_name">SarahM</string>
    <string name="review3_content">I\'ve tried every tracker out there, but Brainest is the only one that stuck. The simplicity is its superpower.</string>

